# Step 5: Vertical edge detection (Sobel)
kernel_v      = np.array([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]])
vertical_edges = convolve2d(img_gray, kernel_v, mode='same')

fig, axes = plt.subplots(1, 2, figsize=(10, 4))
axes[0].imshow(img_gray, cmap='gray');          axes[0].set_title("Grayscale");              axes[0].axis('off')
axes[1].imshow(np.abs(vertical_edges), cmap='gray'); axes[1].set_title("Vertical Edges");    axes[1].axis('off')
