kernel_h         = np.array([[-1, -2, -1], [0, 0, 0], [1, 2, 1]])
horizontal_edges = np.abs(convolve2d(img_gray, kernel_h, mode='same'))

fig, axes = plt.subplots(1, 2, figsize=(10, 4))
axes[0].imshow(img_gray, cmap='gray');     axes[0].set_title("Grayscale");                  axes[0].axis('off')
axes[1].imshow(horizontal_edges, cmap='gray'); axes[1].set_title("Horizontal Edges");       axes[1].axis('off')
plt.tight_layout()
