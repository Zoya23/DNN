BASE_DIR  = "indian_currency_new"
TRAIN_DIR = os.path.join(BASE_DIR, "training")
VAL_DIR   = os.path.join(BASE_DIR, "validation")

# Step 1: Explore dataset
print("Base folder contents:", os.listdir(BASE_DIR))
print("Train folder contents:", os.listdir(TRAIN_DIR))
print("Validation folder contents:", os.listdir(VAL_DIR))

# Step 2: Class counts
classes   = sorted(os.listdir(TRAIN_DIR))
class2idx = {c: i for i, c in enumerate(classes)}
print("\nClasses:", classes)
for c in classes:
    n_tr  = len(os.listdir(os.path.join(TRAIN_DIR, c)))
    n_val = len(os.listdir(os.path.join(VAL_DIR, c)))
    print(f"  {c}: train={n_tr}, val={n_val}")

# Step 3: View random images
def load_random_img(folder):
    cls      = random.choice(os.listdir(folder))
    path     = os.path.join(folder, cls)
    img_name = random.choice(os.listdir(path))
    img      = Image.open(os.path.join(path, img_name)).convert('RGB')
    return img, cls

random.seed(42)
tr_img,  tr_cls  = load_random_img(TRAIN_DIR)
val_img, val_cls = load_random_img(VAL_DIR)

fig, axes = plt.subplots(1, 2, figsize=(10, 4))
axes[0].imshow(tr_img);  axes[0].set_title(f"Training - Rs.{tr_cls}");  axes[0].axis('off')
axes[1].imshow(val_img); axes[1].set_title(f"Validation - Rs.{val_cls}"); axes[1].axis('off')
plt.suptitle("Random Samples from Dataset", fontsize=12, fontweight='bold')
plt.tight_layout()
plt.show()

# Step 4: Convolution with identity kernel
sample_path = os.path.join(TRAIN_DIR, '10', os.listdir(os.path.join(TRAIN_DIR, '10'))[0])
img_bgr  = np.array(Image.open(sample_path).convert('RGB'))
img_gray = np.array(Image.open(sample_path).convert('L'), dtype=np.float32)

kernel_identity = np.array([[0, 0, 0], [0, 1, 0], [0, 0, 0]])
conv_img = convolve2d(img_gray, kernel_identity, mode='valid')

fig, axes = plt.subplots(1, 3, figsize=(14, 4))
axes[0].imshow(img_bgr);            axes[0].set_title("Original Image");              axes[0].axis('off')
